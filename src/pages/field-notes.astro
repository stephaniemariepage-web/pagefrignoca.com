---
import Base from '../layouts/Base.astro';
---

<Base title="Field Notes | Stephanie Frignoca">
  <section class="container-x py-20 lg:py-28">
    <div class="max-w-3xl">
      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-accent">Field Notes</p>
      <h1 class="mt-4 text-4xl font-bold leading-[1.08] tracking-tight sm:text-5xl">
        Coming soon.
      </h1>
      <p class="mt-6 text-lg leading-relaxed text-muted">
        Field Notes is the writing track for this site. Longer takes on the upstream
        layer of GTM data: what AI-ready actually means, why composite scores lie,
        what gated readiness changes about how teams plan, and how to design data
        governance that holds up after the consultant leaves.
      </p>
      <p class="mt-4 text-lg leading-relaxed text-muted">
        First posts ship after launch. Until then, the same arguments live in shorter
        form on LinkedIn.
      </p>
      <div class="mt-10 flex flex-wrap items-center gap-3">
        <a
          href="https://linkedin.com/in/stephaniepagefrignoca"
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-2 rounded-lg border border-line px-5 py-3 text-sm font-semibold text-fg transition hover:border-accent hover:text-accent"
        >
          Read on LinkedIn
        </a>
        <a
          href="mailto:stephaniemariepage@gmail.com?subject=pagefrignoca.com%20field%20notes"
          class="inline-flex items-center gap-2 rounded-lg border border-line px-5 py-3 text-sm font-semibold text-muted transition hover:border-accent hover:text-accent"
        >
          Tell me what you want to read
        </a>
      </div>
    </div>
  </section>
</Base>
