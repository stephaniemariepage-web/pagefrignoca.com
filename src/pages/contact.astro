---
import Base from '../layouts/Base.astro';

const linkedin = 'https://linkedin.com/in/stephaniepagefrignoca';
// Email is assembled client-side from these parts to reduce scraping.
const emailUser = 'stephaniemariepage';
const emailDomain = 'gmail.com';
---

<Base title="Contact | Stephanie Frignoca">
  <section class="relative overflow-hidden">
    <div
      class="pointer-events-none absolute inset-x-0 top-0 h-[520px]"
      style="background: radial-gradient(48% 50% at 50% -6%, rgba(79,209,165,0.10), transparent 72%)"
    >
    </div>

    <div class="container-x relative py-10 lg:py-14">
      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-accent">Contact</p>
      <h1 class="mt-4 text-4xl font-bold leading-[1.08] tracking-tight sm:text-5xl">
        Get in touch
      </h1>
      <p class="mt-6 max-w-2xl text-lg leading-relaxed text-muted">
        I am always glad to hear from people working on interesting data, RevOps, or
        GTM-systems problems. If something here sparked a thought, or you just want to
        connect, drop me a line. Based in Austin, TX.
      </p>

      <div class="mt-12 grid max-w-xl gap-px overflow-hidden rounded-2xl border border-line bg-line">
        <div class="bg-surface p-6 sm:p-8">
          <h2 class="text-xs font-semibold uppercase tracking-[0.2em] text-muted">Email</h2>
          <a
            id="email-link"
            href="#"
            class="mt-3 inline-block text-lg font-medium text-fg transition hover:text-accent"
            data-user={emailUser}
            data-domain={emailDomain}
          >
            {emailUser} [at] {emailDomain.replace('.', ' [dot] ')}
          </a>
        </div>

        <div class="bg-surface p-6 sm:p-8">
          <h2 class="text-xs font-semibold uppercase tracking-[0.2em] text-muted">LinkedIn</h2>
          <a
            href={linkedin}
            target="_blank"
            rel="noopener"
            class="mt-3 inline-block text-lg font-medium text-fg transition hover:text-accent"
          >
            linkedin.com/in/stephaniepagefrignoca
          </a>
        </div>
      </div>
    </div>
  </section>
</Base>

<script>
  // Assemble the mailto link client-side to keep the raw address out of the HTML.
  const emailLink = document.getElementById('email-link') as HTMLAnchorElement | null;
  if (emailLink) {
    const user = emailLink.dataset.user;
    const domain = emailLink.dataset.domain;
    const addr = `${user}@${domain}`;
    emailLink.href = `mailto:${addr}`;
    emailLink.textContent = addr;
  }
</script>
