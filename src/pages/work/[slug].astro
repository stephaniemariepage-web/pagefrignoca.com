---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const entries = await getCollection('work', (e) => !e.data.draft);
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const d = entry.data;
---

<Base title={`${d.title} | Stephanie Frignoca`} description={d.summary}>
  <!-- Page header -->
  <section class="relative overflow-hidden">
    <div
      class="pointer-events-none absolute inset-x-0 top-0 h-[520px]"
      style="background: radial-gradient(48% 50% at 50% -6%, rgba(79,209,165,0.10), transparent 72%)"
    >
    </div>
    <div class="container-x relative py-20 lg:py-28">
      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-accent">{d.hero.eyebrow}</p>
      <h1 class="mt-4 max-w-3xl text-4xl font-bold leading-[1.08] tracking-tight sm:text-5xl lg:text-6xl">
        {d.title}
      </h1>
      <div class="mt-5 flex flex-wrap gap-2">
        <span class="rounded-full border border-line bg-surface px-3 py-1 text-xs font-medium text-muted">
          {d.type}
        </span>
        {d.employer && (
          <span class="rounded-full border border-line bg-surface px-3 py-1 text-xs font-medium text-muted">
            {d.employer}
          </span>
        )}
      </div>
      <p class="mt-6 max-w-2xl text-lg leading-relaxed text-muted">
        {d.hero.intro}
      </p>
    </div>
  </section>

  {d.overview && (
    <section class="border-t border-line/60">
      <div class="container-x py-20 lg:py-24">
        <div class="max-w-3xl">
          <p class="text-xs font-semibold uppercase tracking-[0.2em] text-accent">Overview</p>
          <h2 class="mt-4 text-3xl font-bold tracking-tight sm:text-4xl">
            {d.overview.headline}
          </h2>
          {d.overview.paragraphs.map((p, i) => (
            <p class:list={['text-lg leading-relaxed text-muted', i === 0 ? 'mt-6' : 'mt-4']}>
              {p}
            </p>
          ))}
        </div>
        {d.overview.pullLine && (
          <p class="mt-10 border-l-2 border-accent pl-5 text-xl font-semibold leading-snug sm:text-2xl">
            {d.overview.pullLine}
          </p>
        )}
      </div>
    </section>
  )}

  {d.problem && (
    <section class="border-t border-line/60">
      <div class="container-x py-20 lg:py-24">
        <div class="max-w-3xl">
          <p class="text-xs font-semibold uppercase tracking-[0.2em] text-accent">The problem</p>
          <h2 class="mt-4 text-3xl font-bold tracking-tight sm:text-4xl">
            {d.problem.headline}
          </h2>
          {d.problem.intro && (
            <p class="mt-6 text-lg leading-relaxed text-muted">{d.problem.intro}</p>
          )}
        </div>
        <ol class="mt-10 grid gap-4 sm:grid-cols-2">
          {d.problem.items.map((item, i) => (
            <li class="rounded-xl border border-line bg-surface p-5">
              <div class="flex items-baseline gap-3">
                <span class="text-sm font-semibold text-accent">0{i + 1}</span>
                <h3 class="text-base font-semibold leading-snug">{item.title}</h3>
              </div>
              <p class="mt-3 text-muted">{item.body}</p>
            </li>
          ))}
        </ol>
        {d.problem.pullLine && (
          <p class="mt-10 border-l-2 border-accent pl-5 text-xl font-semibold leading-snug sm:text-2xl">
            {d.problem.pullLine}
          </p>
        )}
      </div>
    </section>
  )}

  {d.framework && (
    <section class="border-t border-line/60">
      <div class="container-x py-20 lg:py-24">
        <div class="max-w-3xl">
          <p class="text-xs font-semibold uppercase tracking-[0.2em] text-accent">The framework</p>
          <h2 class="mt-4 text-3xl font-bold tracking-tight sm:text-4xl">
            {d.framework.headline}
          </h2>
          {d.framework.intro && (
            <p class="mt-6 text-lg leading-relaxed text-muted">{d.framework.intro}</p>
          )}
        </div>
        {d.framework.dimensions && d.framework.dimensions.length > 0 && (
          <div class="mt-8 grid gap-4 sm:grid-cols-3">
            {d.framework.dimensions.map((dim) => (
              <div class="rounded-xl border border-line bg-surface p-5">
                <div class="text-sm font-semibold uppercase tracking-wide text-accent">{dim.name}</div>
                <p class="mt-2 text-muted">{dim.note}</p>
              </div>
            ))}
          </div>
        )}
        {d.framework.paragraphs && d.framework.paragraphs.length > 0 && (
          <div class="mt-8 max-w-3xl space-y-4 text-lg leading-relaxed text-muted">
            {d.framework.paragraphs.map((p) => <p>{p}</p>)}
          </div>
        )}
        {d.framework.scorecardLink && (
          <div class="mt-8">
            <a
              href="/scorecard"
              class="inline-flex items-center gap-1.5 text-sm font-medium text-accent transition hover:brightness-110"
            >
              See the framework run in the Scorecard
              <span aria-hidden="true">&rarr;</span>
            </a>
          </div>
        )}
        {d.framework.pullLine && (
          <p class="mt-10 border-l-2 border-accent pl-5 text-xl font-semibold leading-snug sm:text-2xl">
            {d.framework.pullLine}
          </p>
        )}
      </div>
    </section>
  )}

  {d.builds && (
    <section class="border-t border-line/60">
      <div class="container-x py-20 lg:py-24">
        <div class="max-w-3xl">
          <p class="text-xs font-semibold uppercase tracking-[0.2em] text-accent">What I built</p>
          <h2 class="mt-4 text-3xl font-bold tracking-tight sm:text-4xl">
            {d.builds.headline}
          </h2>
        </div>
        <div class="mt-10 grid gap-4 lg:grid-cols-2">
          {d.builds.items.map((b) => (
            <div class="rounded-xl border border-line bg-surface p-6">
              <h3 class="text-base font-semibold">{b.title}</h3>
              <p class="mt-3 text-muted">{b.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  {d.outcomes && (
    <section class="border-t border-line/60">
      <div class="container-x py-20 lg:py-24">
        <div class="max-w-3xl">
          <p class="text-xs font-semibold uppercase tracking-[0.2em] text-accent">Outcomes</p>
          <h2 class="mt-4 text-3xl font-bold tracking-tight sm:text-4xl">
            {d.outcomes.headline}
          </h2>
        </div>
        <ul class="mt-10 grid gap-3 sm:grid-cols-2">
          {d.outcomes.items.map((o) => (
            <li class="flex gap-3 rounded-xl border border-line bg-surface p-5">
              <span class="mt-2 inline-block h-1.5 w-1.5 flex-none rounded-full bg-accent"></span>
              <span class="text-muted">{o}</span>
            </li>
          ))}
        </ul>
        {d.outcomes.pullLine && (
          <p class="mt-10 border-l-2 border-accent pl-5 text-xl font-semibold leading-snug sm:text-2xl">
            {d.outcomes.pullLine}
          </p>
        )}
      </div>
    </section>
  )}

  {d.portablePOV && (
    <section class="border-t border-line/60">
      <div class="container-x py-20 lg:py-24">
        <div class="max-w-3xl">
          <p class="text-xs font-semibold uppercase tracking-[0.2em] text-accent">The portable POV</p>
          <h2 class="mt-4 text-3xl font-bold tracking-tight sm:text-4xl">
            {d.portablePOV.headline}
          </h2>
          {d.portablePOV.intro && (
            <p class="mt-6 text-lg leading-relaxed text-muted">{d.portablePOV.intro}</p>
          )}
        </div>
        <div class="mt-10 grid gap-4 sm:grid-cols-3">
          {d.portablePOV.points.map((p) => (
            <div class="rounded-xl border border-line bg-surface p-5">
              <h3 class="text-base font-semibold leading-snug">{p.title}</h3>
              <p class="mt-3 text-muted">{p.body}</p>
            </div>
          ))}
        </div>
        {d.portablePOV.pullLine && (
          <p class="mt-10 border-l-2 border-accent pl-5 text-xl font-semibold leading-snug sm:text-2xl">
            {d.portablePOV.pullLine}
          </p>
        )}
      </div>
    </section>
  )}

  {d.closing && (
    <section class="border-t border-line/60">
      <div class="container-x py-20 lg:py-28">
        <div
          class="rounded-2xl border border-line p-8 sm:p-14"
          style="background: linear-gradient(180deg, #0f1214 0%, #08090b 100%)"
        >
          <h2 class="max-w-2xl text-3xl font-bold tracking-tight sm:text-4xl">
            {d.closing.headline}
          </h2>
          <p class="mt-5 max-w-xl text-lg leading-relaxed text-muted">
            {d.closing.body}
          </p>
          <div class="mt-8 flex flex-wrap gap-3">
            {d.closing.primaryCta && (
              <a
                href={d.closing.primaryCta.href}
                class="inline-flex items-center gap-2 rounded-lg bg-accent px-5 py-3 text-sm font-semibold text-[#06231b] transition hover:brightness-110"
              >
                {d.closing.primaryCta.label}
              </a>
            )}
            {d.closing.secondaryCta && (
              <a
                href={d.closing.secondaryCta.href}
                class="inline-flex items-center gap-2 rounded-lg border border-line px-5 py-3 text-sm font-semibold text-fg transition hover:border-accent hover:text-accent"
              >
                {d.closing.secondaryCta.label}
              </a>
            )}
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- Back to portfolio -->
  <section class="border-t border-line/60">
    <div class="container-x py-12">
      <a
        href="/work"
        class="inline-flex items-center gap-1.5 text-sm font-medium text-muted transition hover:text-accent"
      >
        <span aria-hidden="true">&larr;</span>
        Back to all work
      </a>
    </div>
  </section>
</Base>
