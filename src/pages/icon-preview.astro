---
import Base from '../layouts/Base.astro';

const MINT = '#4fd1a5';
const ORANGE = '#ec6a4d';

const options = [
  {
    key: 'A',
    label: 'Current — pause + accent',
    description:
      'Two tall mint bars + one short offset orange bar. Stable + accent composition.',
  },
  {
    key: 'B',
    label: 'Stepped score',
    description:
      'Three rising bars, the tallest in orange. Reads as scoring / bar chart.',
  },
  {
    key: 'C',
    label: 'Bar + gate dot',
    description:
      'Two mint bars with an orange dot above. References the gated readiness concept.',
  },
  {
    key: 'D',
    label: 'Square + corner notch',
    description:
      'Solid mint square with an orange-notched corner. Pure geometric mark.',
  },
];
---

<Base title="Icon preview | Stephanie Frignoca">
  <section class="container-x py-16 lg:py-20">
    <p class="text-xs font-semibold uppercase tracking-[0.2em] text-accent">Internal preview</p>
    <h1 class="mt-4 text-3xl font-bold tracking-tight sm:text-4xl">
      Header icon options
    </h1>
    <p class="mt-4 max-w-2xl text-base leading-relaxed text-muted">
      All four icons rendered at header size (20px) and large size (96px) on the same
      dark background as the live site. Reply with A, B, C, or D.
    </p>

    <div class="mt-12 grid gap-8 md:grid-cols-2">
      {options.map((opt) => (
        <div class="rounded-2xl border border-line bg-surface p-8">
          <div class="flex items-baseline gap-3">
            <span class="rounded-md border border-line bg-bg px-2 py-0.5 text-sm font-bold text-accent">
              {opt.key}
            </span>
            <h2 class="text-lg font-semibold tracking-tight">{opt.label}</h2>
          </div>
          <p class="mt-2 text-sm text-muted">{opt.description}</p>

          <!-- Header-size preview, inside a mock nav -->
          <div class="mt-6 rounded-lg border border-line/70 bg-bg p-3">
            <p class="mb-2 text-[10px] uppercase tracking-wider text-muted/60">Header size (20px)</p>
            <div class="flex h-10 items-center gap-2.5">
              {opt.key === 'A' && (
                <svg width="20" height="20" viewBox="0 0 32 32" aria-hidden="true">
                  <rect x="6" y="8" width="5" height="16" rx="2.5" fill={MINT} />
                  <rect x="14" y="8" width="5" height="16" rx="2.5" fill={MINT} />
                  <rect x="22" y="18" width="5" height="6" rx="2.5" fill={ORANGE} />
                </svg>
              )}
              {opt.key === 'B' && (
                <svg width="20" height="20" viewBox="0 0 32 32" aria-hidden="true">
                  <rect x="5"  y="20" width="5" height="8"  rx="1.5" fill={MINT} />
                  <rect x="12" y="14" width="5" height="14" rx="1.5" fill={MINT} />
                  <rect x="19" y="6"  width="5" height="22" rx="1.5" fill={ORANGE} />
                </svg>
              )}
              {opt.key === 'C' && (
                <svg width="20" height="20" viewBox="0 0 32 32" aria-hidden="true">
                  <rect x="8"  y="10" width="5" height="18" rx="2.5" fill={MINT} />
                  <rect x="19" y="10" width="5" height="18" rx="2.5" fill={MINT} />
                  <circle cx="16" cy="5" r="2.6" fill={ORANGE} />
                </svg>
              )}
              {opt.key === 'D' && (
                <svg width="20" height="20" viewBox="0 0 32 32" aria-hidden="true">
                  <path d="M6 6 H26 V20 L20 26 H6 Z" fill={MINT} />
                  <path d="M26 20 L26 26 L20 26 Z" fill={ORANGE} />
                </svg>
              )}
              <span class="text-[15px] font-medium text-muted">[ nav links ]</span>
            </div>
          </div>

          <!-- Large preview -->
          <div class="mt-4 rounded-lg border border-line/70 bg-bg p-6">
            <p class="mb-3 text-[10px] uppercase tracking-wider text-muted/60">Large (96px)</p>
            <div class="flex justify-center">
              {opt.key === 'A' && (
                <svg width="96" height="96" viewBox="0 0 32 32" aria-hidden="true">
                  <rect x="6" y="8" width="5" height="16" rx="2.5" fill={MINT} />
                  <rect x="14" y="8" width="5" height="16" rx="2.5" fill={MINT} />
                  <rect x="22" y="18" width="5" height="6" rx="2.5" fill={ORANGE} />
                </svg>
              )}
              {opt.key === 'B' && (
                <svg width="96" height="96" viewBox="0 0 32 32" aria-hidden="true">
                  <rect x="5"  y="20" width="5" height="8"  rx="1.5" fill={MINT} />
                  <rect x="12" y="14" width="5" height="14" rx="1.5" fill={MINT} />
                  <rect x="19" y="6"  width="5" height="22" rx="1.5" fill={ORANGE} />
                </svg>
              )}
              {opt.key === 'C' && (
                <svg width="96" height="96" viewBox="0 0 32 32" aria-hidden="true">
                  <rect x="8"  y="10" width="5" height="18" rx="2.5" fill={MINT} />
                  <rect x="19" y="10" width="5" height="18" rx="2.5" fill={MINT} />
                  <circle cx="16" cy="5" r="2.6" fill={ORANGE} />
                </svg>
              )}
              {opt.key === 'D' && (
                <svg width="96" height="96" viewBox="0 0 32 32" aria-hidden="true">
                  <path d="M6 6 H26 V20 L20 26 H6 Z" fill={MINT} />
                  <path d="M26 20 L26 26 L20 26 Z" fill={ORANGE} />
                </svg>
              )}
            </div>
          </div>
        </div>
      ))}
    </div>

    <p class="mt-12 text-xs text-muted/60">
      This page exists for preview only and will be removed after you pick.
    </p>
  </section>
</Base>
