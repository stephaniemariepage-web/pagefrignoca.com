---
import Base from '../layouts/Base.astro';

const MINT = '#4fd1a5';
const ORANGE = '#ec6a4d';

const abstract = [
  {
    key: 'A',
    label: 'Current — pause + accent',
    description: 'Two tall mint bars + short offset orange bar.',
  },
  {
    key: 'B',
    label: 'Stepped score',
    description: 'Three rising bars, tallest in orange. Scoring vibe.',
  },
  {
    key: 'C',
    label: 'Bar + gate dot',
    description: 'Two mint bars, orange dot floating above the gap.',
  },
  {
    key: 'D',
    label: 'Square + corner notch',
    description: 'Solid mint square with orange-notched corner.',
  },
];

const checkVariants = [
  {
    key: 'N',
    label: 'Check, mint short + orange long',
    description: 'Same split as I, hexagon removed. Mint leads, orange completes the sweep.',
  },
  {
    key: 'O',
    label: 'Check, orange short + mint long',
    description: 'Flipped split. A short orange accent kicks off, mint carries the full sweep.',
  },
  {
    key: 'P',
    label: 'Check, all mint + orange pivot dot',
    description: 'Full mint check with a small orange dot at the vertex. Quiet accent.',
  },
  {
    key: 'Q',
    label: 'Check, mostly mint + orange tip',
    description: 'Most of the check is mint, just the final tip lands in orange.',
  },
  {
    key: 'R',
    label: 'Hexagon + Q-style check (mostly mint, orange tip)',
    description: 'I and Q combined. Hex container, bold check, mostly mint with just the tip orange.',
  },
];

const illustrative = [
  {
    key: 'E',
    label: 'Layered diamonds + top dot',
    description: 'Stacked isometric layers, orange diamond floating above.',
  },
  {
    key: 'F',
    label: 'Hex network',
    description: 'Hexagon with vertex nodes, orange circle at center.',
  },
  {
    key: 'G',
    label: 'Grid + center cell',
    description: '3x3 grid with the center cell filled orange.',
  },
  {
    key: 'H',
    label: 'Stacked records',
    description: 'Three offset cards, top card has an orange marker.',
  },
  {
    key: 'I',
    label: 'Hexagon + check',
    description: 'Hex outline with a check, split mint/orange. Most thematic.',
  },
  {
    key: 'J',
    label: 'Funnel + signals',
    description: 'Funnel with three squares above, middle one orange.',
  },
  {
    key: 'K',
    label: 'Layered diamonds + spine',
    description: 'Stacked layers with a dashed vertical line through them.',
  },
  {
    key: 'L',
    label: 'Brackets + crosshair',
    description: 'Corner brackets with a dotted X and orange diamond center.',
  },
  {
    key: 'M',
    label: 'Hierarchy tree',
    description: 'Parent box with three children, middle child orange.',
  },
];
---

<Base title="Icon preview | Stephanie Frignoca">
  <section class="container-x py-16 lg:py-20">
    <p class="text-xs font-semibold uppercase tracking-[0.2em] text-accent">Internal preview</p>
    <h1 class="mt-4 text-3xl font-bold tracking-tight sm:text-4xl">
      Header icon options
    </h1>
    <p class="mt-4 max-w-2xl text-base leading-relaxed text-muted">
      All 13 candidate marks rendered at header size (20px, inside a mock nav)
      and large size (96px) on the live dark background. Reply with the letter
      to pick.
    </p>

    <!-- ABSTRACT MARKS -->
    <div class="mt-12">
      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-muted">Abstract studio marks (A–D)</p>
      <div class="mt-5 grid gap-5 md:grid-cols-2 lg:grid-cols-3">
        {abstract.map((opt) => (
          <div class="rounded-2xl border border-line bg-surface p-6">
            <div class="flex items-baseline gap-2.5">
              <span class="rounded-md border border-line bg-bg px-1.5 py-0.5 text-sm font-bold text-accent">
                {opt.key}
              </span>
              <h2 class="text-sm font-semibold tracking-tight">{opt.label}</h2>
            </div>
            <p class="mt-1.5 text-xs leading-relaxed text-muted">{opt.description}</p>
            <div class="mt-4 rounded-lg border border-line/70 bg-bg p-3">
              <div class="flex h-9 items-center gap-2">
                {opt.key === 'A' && (
                  <svg width="20" height="20" viewBox="0 0 32 32" aria-hidden="true">
                    <rect x="6" y="8" width="5" height="16" rx="2.5" fill={MINT} />
                    <rect x="14" y="8" width="5" height="16" rx="2.5" fill={MINT} />
                    <rect x="22" y="18" width="5" height="6" rx="2.5" fill={ORANGE} />
                  </svg>
                )}
                {opt.key === 'B' && (
                  <svg width="20" height="20" viewBox="0 0 32 32" aria-hidden="true">
                    <rect x="5"  y="20" width="5" height="8"  rx="1.5" fill={MINT} />
                    <rect x="12" y="14" width="5" height="14" rx="1.5" fill={MINT} />
                    <rect x="19" y="6"  width="5" height="22" rx="1.5" fill={ORANGE} />
                  </svg>
                )}
                {opt.key === 'C' && (
                  <svg width="20" height="20" viewBox="0 0 32 32" aria-hidden="true">
                    <rect x="8"  y="10" width="5" height="18" rx="2.5" fill={MINT} />
                    <rect x="19" y="10" width="5" height="18" rx="2.5" fill={MINT} />
                    <circle cx="16" cy="5" r="2.6" fill={ORANGE} />
                  </svg>
                )}
                {opt.key === 'D' && (
                  <svg width="20" height="20" viewBox="0 0 32 32" aria-hidden="true">
                    <path d="M6 6 H26 V20 L20 26 H6 Z" fill={MINT} />
                    <path d="M26 20 L26 26 L20 26 Z" fill={ORANGE} />
                  </svg>
                )}
                <span class="text-[13px] text-muted">[ nav links ]</span>
              </div>
            </div>
            <div class="mt-3 flex justify-center rounded-lg border border-line/70 bg-bg p-4">
              {opt.key === 'A' && (
                <svg width="80" height="80" viewBox="0 0 32 32" aria-hidden="true">
                  <rect x="6" y="8" width="5" height="16" rx="2.5" fill={MINT} />
                  <rect x="14" y="8" width="5" height="16" rx="2.5" fill={MINT} />
                  <rect x="22" y="18" width="5" height="6" rx="2.5" fill={ORANGE} />
                </svg>
              )}
              {opt.key === 'B' && (
                <svg width="80" height="80" viewBox="0 0 32 32" aria-hidden="true">
                  <rect x="5"  y="20" width="5" height="8"  rx="1.5" fill={MINT} />
                  <rect x="12" y="14" width="5" height="14" rx="1.5" fill={MINT} />
                  <rect x="19" y="6"  width="5" height="22" rx="1.5" fill={ORANGE} />
                </svg>
              )}
              {opt.key === 'C' && (
                <svg width="80" height="80" viewBox="0 0 32 32" aria-hidden="true">
                  <rect x="8"  y="10" width="5" height="18" rx="2.5" fill={MINT} />
                  <rect x="19" y="10" width="5" height="18" rx="2.5" fill={MINT} />
                  <circle cx="16" cy="5" r="2.6" fill={ORANGE} />
                </svg>
              )}
              {opt.key === 'D' && (
                <svg width="80" height="80" viewBox="0 0 32 32" aria-hidden="true">
                  <path d="M6 6 H26 V20 L20 26 H6 Z" fill={MINT} />
                  <path d="M26 20 L26 26 L20 26 Z" fill={ORANGE} />
                </svg>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- ILLUSTRATIVE ICONS -->
    <div class="mt-12">
      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-muted">Illustrative icons (E–M)</p>
      <div class="mt-5 grid gap-5 md:grid-cols-2 lg:grid-cols-3">
        {illustrative.map((opt) => (
          <div class="rounded-2xl border border-line bg-surface p-6">
            <div class="flex items-baseline gap-2.5">
              <span class="rounded-md border border-line bg-bg px-1.5 py-0.5 text-sm font-bold text-accent">
                {opt.key}
              </span>
              <h2 class="text-sm font-semibold tracking-tight">{opt.label}</h2>
            </div>
            <p class="mt-1.5 text-xs leading-relaxed text-muted">{opt.description}</p>
            <div class="mt-4 rounded-lg border border-line/70 bg-bg p-3">
              <div class="flex h-9 items-center gap-2">
                {opt.key === 'E' && (
                  <svg width="22" height="22" viewBox="0 0 64 64" fill="none" aria-hidden="true">
                    <g stroke={MINT} stroke-width="2.5" stroke-linejoin="round">
                      <path d="M32 16 L54 26 L32 36 L10 26 Z" />
                      <path d="M32 26 L54 36 L32 46 L10 36 Z" />
                      <path d="M32 36 L54 46 L32 56 L10 46 Z" />
                    </g>
                    <path d="M32 4 L38 10 L32 16 L26 10 Z" fill={ORANGE} />
                  </svg>
                )}
                {opt.key === 'F' && (
                  <svg width="22" height="22" viewBox="0 0 64 64" fill="none" aria-hidden="true">
                    <g stroke={MINT} stroke-width="2" stroke-linejoin="round" stroke-linecap="round">
                      <path d="M54 32 L43 51 L21 51 L10 32 L21 13 L43 13 Z" />
                      <line x1="54" y1="32" x2="10" y2="32" />
                      <line x1="43" y1="51" x2="21" y2="13" />
                      <line x1="21" y1="51" x2="43" y2="13" />
                    </g>
                    <circle cx="54" cy="32" r="3" fill={MINT} />
                    <circle cx="43" cy="51" r="3" fill={MINT} />
                    <circle cx="21" cy="51" r="3" fill={MINT} />
                    <circle cx="10" cy="32" r="3" fill={MINT} />
                    <circle cx="21" cy="13" r="3" fill={MINT} />
                    <circle cx="43" cy="13" r="3" fill={MINT} />
                    <circle cx="32" cy="32" r="5" fill="none" stroke={ORANGE} stroke-width="2.5" />
                  </svg>
                )}
                {opt.key === 'G' && (
                  <svg width="22" height="22" viewBox="0 0 64 64" fill="none" aria-hidden="true">
                    <g stroke={MINT} stroke-width="2.5" stroke-linejoin="round">
                      <rect x="10" y="10" width="44" height="44" rx="2" />
                      <line x1="24.67" y1="10" x2="24.67" y2="54" />
                      <line x1="39.33" y1="10" x2="39.33" y2="54" />
                      <line x1="10" y1="24.67" x2="54" y2="24.67" />
                      <line x1="10" y1="39.33" x2="54" y2="39.33" />
                    </g>
                    <rect x="27" y="27" width="10" height="10" fill={ORANGE} />
                  </svg>
                )}
                {opt.key === 'H' && (
                  <svg width="22" height="22" viewBox="0 0 64 64" fill="none" aria-hidden="true">
                    <g stroke={MINT} stroke-width="2.5" stroke-linejoin="round" stroke-linecap="round">
                      <rect x="20" y="20" width="36" height="36" rx="3" fill="#0a0c10" />
                      <rect x="14" y="14" width="36" height="36" rx="3" fill="#0a0c10" />
                      <rect x="8" y="8" width="36" height="36" rx="3" fill="#0a0c10" />
                      <line x1="14" y1="22" x2="32" y2="22" />
                      <line x1="14" y1="30" x2="28" y2="30" />
                    </g>
                    <circle cx="38" cy="22" r="3" fill={ORANGE} />
                  </svg>
                )}
                {opt.key === 'I' && (
                  <svg width="22" height="22" viewBox="0 0 64 64" fill="none" aria-hidden="true">
                    <path d="M32 6 L54 19 L54 45 L32 58 L10 45 L10 19 Z" stroke={MINT} stroke-width="2.5" stroke-linejoin="round" />
                    <path d="M20 33 L30 43" stroke={MINT} stroke-width="3.5" stroke-linecap="round" />
                    <path d="M30 43 L46 25" stroke={ORANGE} stroke-width="3.5" stroke-linecap="round" />
                  </svg>
                )}
                {opt.key === 'J' && (
                  <svg width="22" height="22" viewBox="0 0 64 64" fill="none" aria-hidden="true">
                    <path d="M12 28 L52 28 L36 44 L36 56 L28 56 L28 44 Z" stroke={MINT} stroke-width="2.5" stroke-linejoin="round" />
                    <rect x="14" y="12" width="7" height="7" fill={MINT} />
                    <rect x="29" y="12" width="7" height="7" fill={ORANGE} />
                    <rect x="44" y="12" width="7" height="7" fill={MINT} />
                  </svg>
                )}
                {opt.key === 'K' && (
                  <svg width="22" height="22" viewBox="0 0 64 64" fill="none" aria-hidden="true">
                    <g stroke={MINT} stroke-width="2.5" stroke-linejoin="round">
                      <path d="M32 12 L54 22 L32 32 L10 22 Z" />
                      <path d="M32 24 L54 34 L32 44 L10 34 Z" />
                      <path d="M32 36 L54 46 L32 56 L10 46 Z" />
                    </g>
                    <line x1="32" y1="6" x2="32" y2="60" stroke={MINT} stroke-width="2" stroke-dasharray="2 3" />
                    <circle cx="32" cy="34" r="3.5" fill={ORANGE} />
                  </svg>
                )}
                {opt.key === 'L' && (
                  <svg width="22" height="22" viewBox="0 0 64 64" fill="none" aria-hidden="true">
                    <g stroke={MINT} stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" fill="none">
                      <path d="M10 16 L10 10 L16 10" />
                      <path d="M48 10 L54 10 L54 16" />
                      <path d="M10 48 L10 54 L16 54" />
                      <path d="M48 54 L54 54 L54 48" />
                      <line x1="20" y1="20" x2="28" y2="28" stroke-dasharray="2 2" />
                      <line x1="44" y1="20" x2="36" y2="28" stroke-dasharray="2 2" />
                      <line x1="20" y1="44" x2="28" y2="36" stroke-dasharray="2 2" />
                      <line x1="44" y1="44" x2="36" y2="36" stroke-dasharray="2 2" />
                    </g>
                    <circle cx="20" cy="20" r="2.5" fill={MINT} />
                    <circle cx="44" cy="20" r="2.5" fill={MINT} />
                    <circle cx="20" cy="44" r="2.5" fill={MINT} />
                    <circle cx="44" cy="44" r="2.5" fill={MINT} />
                    <path d="M32 26 L38 32 L32 38 L26 32 Z" fill={ORANGE} />
                  </svg>
                )}
                {opt.key === 'M' && (
                  <svg width="22" height="22" viewBox="0 0 64 64" fill="none" aria-hidden="true">
                    <g stroke={MINT} stroke-width="2.5" stroke-linejoin="round" fill="none">
                      <rect x="24" y="10" width="16" height="12" rx="1" />
                      <rect x="6" y="42" width="14" height="12" rx="1" />
                      <rect x="44" y="42" width="14" height="12" rx="1" />
                      <path d="M32 22 L32 32 M13 32 L51 32 M13 32 L13 42 M51 32 L51 42 M32 32 L32 42" />
                    </g>
                    <rect x="25" y="42" width="14" height="12" rx="1" fill={ORANGE} />
                  </svg>
                )}
                <span class="text-[13px] text-muted">[ nav links ]</span>
              </div>
            </div>
            <div class="mt-3 flex justify-center rounded-lg border border-line/70 bg-bg p-4">
              {opt.key === 'E' && (
                <svg width="88" height="88" viewBox="0 0 64 64" fill="none" aria-hidden="true">
                  <g stroke={MINT} stroke-width="2.5" stroke-linejoin="round">
                    <path d="M32 16 L54 26 L32 36 L10 26 Z" />
                    <path d="M32 26 L54 36 L32 46 L10 36 Z" />
                    <path d="M32 36 L54 46 L32 56 L10 46 Z" />
                  </g>
                  <path d="M32 4 L38 10 L32 16 L26 10 Z" fill={ORANGE} />
                </svg>
              )}
              {opt.key === 'F' && (
                <svg width="88" height="88" viewBox="0 0 64 64" fill="none" aria-hidden="true">
                  <g stroke={MINT} stroke-width="2" stroke-linejoin="round" stroke-linecap="round">
                    <path d="M54 32 L43 51 L21 51 L10 32 L21 13 L43 13 Z" />
                    <line x1="54" y1="32" x2="10" y2="32" />
                    <line x1="43" y1="51" x2="21" y2="13" />
                    <line x1="21" y1="51" x2="43" y2="13" />
                  </g>
                  <circle cx="54" cy="32" r="3" fill={MINT} />
                  <circle cx="43" cy="51" r="3" fill={MINT} />
                  <circle cx="21" cy="51" r="3" fill={MINT} />
                  <circle cx="10" cy="32" r="3" fill={MINT} />
                  <circle cx="21" cy="13" r="3" fill={MINT} />
                  <circle cx="43" cy="13" r="3" fill={MINT} />
                  <circle cx="32" cy="32" r="5" fill="none" stroke={ORANGE} stroke-width="2.5" />
                </svg>
              )}
              {opt.key === 'G' && (
                <svg width="88" height="88" viewBox="0 0 64 64" fill="none" aria-hidden="true">
                  <g stroke={MINT} stroke-width="2.5" stroke-linejoin="round">
                    <rect x="10" y="10" width="44" height="44" rx="2" />
                    <line x1="24.67" y1="10" x2="24.67" y2="54" />
                    <line x1="39.33" y1="10" x2="39.33" y2="54" />
                    <line x1="10" y1="24.67" x2="54" y2="24.67" />
                    <line x1="10" y1="39.33" x2="54" y2="39.33" />
                  </g>
                  <rect x="27" y="27" width="10" height="10" fill={ORANGE} />
                </svg>
              )}
              {opt.key === 'H' && (
                <svg width="88" height="88" viewBox="0 0 64 64" fill="none" aria-hidden="true">
                  <g stroke={MINT} stroke-width="2.5" stroke-linejoin="round" stroke-linecap="round">
                    <rect x="20" y="20" width="36" height="36" rx="3" fill="#0a0c10" />
                    <rect x="14" y="14" width="36" height="36" rx="3" fill="#0a0c10" />
                    <rect x="8" y="8" width="36" height="36" rx="3" fill="#0a0c10" />
                    <line x1="14" y1="22" x2="32" y2="22" />
                    <line x1="14" y1="30" x2="28" y2="30" />
                  </g>
                  <circle cx="38" cy="22" r="3" fill={ORANGE} />
                </svg>
              )}
              {opt.key === 'I' && (
                <svg width="88" height="88" viewBox="0 0 64 64" fill="none" aria-hidden="true">
                  <path d="M32 6 L54 19 L54 45 L32 58 L10 45 L10 19 Z" stroke={MINT} stroke-width="2.5" stroke-linejoin="round" />
                  <path d="M20 33 L30 43" stroke={MINT} stroke-width="3.5" stroke-linecap="round" />
                  <path d="M30 43 L46 25" stroke={ORANGE} stroke-width="3.5" stroke-linecap="round" />
                </svg>
              )}
              {opt.key === 'J' && (
                <svg width="88" height="88" viewBox="0 0 64 64" fill="none" aria-hidden="true">
                  <path d="M12 28 L52 28 L36 44 L36 56 L28 56 L28 44 Z" stroke={MINT} stroke-width="2.5" stroke-linejoin="round" />
                  <rect x="14" y="12" width="7" height="7" fill={MINT} />
                  <rect x="29" y="12" width="7" height="7" fill={ORANGE} />
                  <rect x="44" y="12" width="7" height="7" fill={MINT} />
                </svg>
              )}
              {opt.key === 'K' && (
                <svg width="88" height="88" viewBox="0 0 64 64" fill="none" aria-hidden="true">
                  <g stroke={MINT} stroke-width="2.5" stroke-linejoin="round">
                    <path d="M32 12 L54 22 L32 32 L10 22 Z" />
                    <path d="M32 24 L54 34 L32 44 L10 34 Z" />
                    <path d="M32 36 L54 46 L32 56 L10 46 Z" />
                  </g>
                  <line x1="32" y1="6" x2="32" y2="60" stroke={MINT} stroke-width="2" stroke-dasharray="2 3" />
                  <circle cx="32" cy="34" r="3.5" fill={ORANGE} />
                </svg>
              )}
              {opt.key === 'L' && (
                <svg width="88" height="88" viewBox="0 0 64 64" fill="none" aria-hidden="true">
                  <g stroke={MINT} stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" fill="none">
                    <path d="M10 16 L10 10 L16 10" />
                    <path d="M48 10 L54 10 L54 16" />
                    <path d="M10 48 L10 54 L16 54" />
                    <path d="M48 54 L54 54 L54 48" />
                    <line x1="20" y1="20" x2="28" y2="28" stroke-dasharray="2 2" />
                    <line x1="44" y1="20" x2="36" y2="28" stroke-dasharray="2 2" />
                    <line x1="20" y1="44" x2="28" y2="36" stroke-dasharray="2 2" />
                    <line x1="44" y1="44" x2="36" y2="36" stroke-dasharray="2 2" />
                  </g>
                  <circle cx="20" cy="20" r="2.5" fill={MINT} />
                  <circle cx="44" cy="20" r="2.5" fill={MINT} />
                  <circle cx="20" cy="44" r="2.5" fill={MINT} />
                  <circle cx="44" cy="44" r="2.5" fill={MINT} />
                  <path d="M32 26 L38 32 L32 38 L26 32 Z" fill={ORANGE} />
                </svg>
              )}
              {opt.key === 'M' && (
                <svg width="88" height="88" viewBox="0 0 64 64" fill="none" aria-hidden="true">
                  <g stroke={MINT} stroke-width="2.5" stroke-linejoin="round" fill="none">
                    <rect x="24" y="10" width="16" height="12" rx="1" />
                    <rect x="6" y="42" width="14" height="12" rx="1" />
                    <rect x="44" y="42" width="14" height="12" rx="1" />
                    <path d="M32 22 L32 32 M13 32 L51 32 M13 32 L13 42 M51 32 L51 42 M32 32 L32 42" />
                  </g>
                  <rect x="25" y="42" width="14" height="12" rx="1" fill={ORANGE} />
                </svg>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- CHECK-ONLY VARIATIONS -->
    <div class="mt-12">
      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-muted">Check-only variations (N–Q)</p>
      <p class="mt-2 max-w-2xl text-sm text-muted/80">
        Hexagon removed. Bold check mark, mostly mint with a touch of orange. Four
        ways to split the color.
      </p>
      <div class="mt-5 grid gap-5 md:grid-cols-2 lg:grid-cols-4">
        {checkVariants.map((opt) => (
          <div class="rounded-2xl border border-line bg-surface p-6">
            <div class="flex items-baseline gap-2.5">
              <span class="rounded-md border border-line bg-bg px-1.5 py-0.5 text-sm font-bold text-accent">
                {opt.key}
              </span>
              <h2 class="text-sm font-semibold tracking-tight">{opt.label}</h2>
            </div>
            <p class="mt-1.5 text-xs leading-relaxed text-muted">{opt.description}</p>
            <div class="mt-4 rounded-lg border border-line/70 bg-bg p-3">
              <div class="flex h-9 items-center gap-2">
                {opt.key === 'N' && (
                  <svg width="22" height="22" viewBox="0 0 64 64" fill="none" aria-hidden="true">
                    <path d="M14 32 L28 46" stroke={MINT} stroke-width="6" stroke-linecap="round" stroke-linejoin="round" />
                    <path d="M28 46 L52 18" stroke={ORANGE} stroke-width="6" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                )}
