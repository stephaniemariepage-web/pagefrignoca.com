---
const path = Astro.url.pathname;
const links = [
  { href: '/', label: 'Work' },
  { href: '/scorecard', label: 'Scorecard' },
  { href: '/about', label: 'About' },
  { href: '/contact', label: 'Contact' },
];
const isActive = (href: string) => path === href || path === href + '/';
---

<header class="sticky top-0 z-50 border-b border-line/70 bg-bg/80 backdrop-blur-md">
  <nav class="container-x flex h-16 items-center justify-between">
    <a
      href="/"
      class="inline-flex items-center gap-2 rounded-md p-1 transition hover:opacity-80 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent"
      aria-label="Stephanie Frignoca, home"
    >
      <svg width="26" height="26" viewBox="0 0 32 32" aria-hidden="true">
        <rect x="6" y="8" width="5" height="16" rx="2.5" fill="#4fd1a5"/>
        <rect x="14" y="8" width="5" height="16" rx="2.5" fill="#4fd1a5"/>
        <rect x="22" y="18" width="5" height="6" rx="2.5" fill="#ec6a4d"/>
      </svg>
      <span aria-hidden="true" class="text-[14px] font-semibold tracking-[0.08em]">SF</span>
    </a>

    <div class="flex items-center gap-5 text-sm">
      {links.map((l) => (
        <a
          href={l.href}
          class={
            'transition hover:text-fg ' +
            (isActive(l.href) ? 'font-medium text-fg' : 'text-muted')
          }
        >
          {l.label}
        </a>
      ))}
    </div>
  </nav>
</header>
