---
const path = Astro.url.pathname;
const links = [
  { href: '/scorecard', label: 'Scorecard' },
  { href: '/work', label: 'Work' },
  { href: '/about', label: 'About' },
  { href: '/field-notes', label: 'Field Notes' },
];
const isActive = (href: string) => path === href || path === href + '/';
---

<header class="sticky top-0 z-50 border-b border-line/70 bg-bg/80 backdrop-blur-md">
  <nav class="container-x flex h-16 items-center justify-between">
    <a
      href="/"
      class="inline-flex items-center rounded-md p-1 transition hover:opacity-80 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent"
      aria-label="Page Frignoca home"
    >
      <svg width="22" height="22" viewBox="0 0 64 64" fill="none" aria-hidden="true">
        <path d="M32 6 L54 19 L54 45 L32 58 L10 45 L10 19 Z" stroke="#4fd1a5" stroke-width="2.5" stroke-linejoin="round" />
        <path d="M20 33 L30 43 L41 30" stroke="#4fd1a5" stroke-width="4" stroke-linecap="round" stroke-linejoin="round" />
        <path d="M41 30 L46 25" stroke="#ec6a4d" stroke-width="4" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
    </a>

    <div class="flex items-center gap-5 text-sm">
      {links.map((l) => (
        <a
          href={l.href}
          class={
            'transition hover:text-fg ' +
            (isActive(l.href) ? 'font-medium text-fg' : 'text-muted')
          }
        >
          {l.label}
        </a>
      ))}
    </div>
  </nav>
</header>
