---
const path = Astro.url.pathname;
const links = [
  { href: '/scorecard', label: 'Scorecard' },
  { href: '/work', label: 'Work' },
  { href: '/about', label: 'About' },
  { href: '/field-notes', label: 'Field Notes' },
];
const isActive = (href: string) => path === href || path === href + '/';
---

<header class="sticky top-0 z-50 border-b border-line/70 bg-bg/80 backdrop-blur-md">
  <nav class="container-x flex h-16 items-center justify-between">
    <a href="/" class="flex items-center gap-2.5" aria-label="Stephanie Frignoca, home">
      <svg width="20" height="20" viewBox="0 0 32 32" aria-hidden="true">
        <rect x="6" y="8" width="5" height="16" rx="2.5" fill="#4fd1a5"></rect>
        <rect x="14" y="8" width="5" height="16" rx="2.5" fill="#4fd1a5"></rect>
        <rect x="22" y="18" width="5" height="6" rx="2.5" fill="#ec6a4d"></rect>
      </svg>
      <span class="text-[15px] font-semibold tracking-tight">Stephanie Frignoca</span>
    </a>

    <div class="flex items-center gap-5 text-sm">
      {links.map((l) => (
        <a
          href={l.href}
          class={
            'transition hover:text-fg ' +
            (isActive(l.href) ? 'font-medium text-fg' : 'text-muted')
          }
        >
          {l.label}
        </a>
      ))}
    </div>
  </nav>
</header>
